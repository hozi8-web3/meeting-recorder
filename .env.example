# ============================================================
# DEVORA DEVS — Meeting Recorder Enterprise Edition
# http://devoradevs.xyz/
# Copy this file to .env and fill in your values.
# DO NOT commit .env to git.
# ============================================================

# === Groq API (Primary LLM Backend) ===
VITE_GROQ_API_KEY=your_groq_api_key_here
VITE_GROQ_BASE_URL=https://api.groq.com/openai/v1

# === Model Selection (swap freely without code changes) ===
VITE_MODEL_SUMMARY=llama-3.3-70b-versatile
VITE_MODEL_DIARIZATION=llama-3.1-8b-instant
VITE_MODEL_EMAIL=llama-3.3-70b-versatile
VITE_MODEL_PRIORITIZER=llama-3.1-8b-instant
VITE_MODEL_HEALTH=llama-3.1-8b-instant

# === Ollama Fallback (optional, for offline-only environments) ===
VITE_OLLAMA_BASE_URL=http://localhost:11434
VITE_OLLAMA_MODEL=llama3.1:8b
VITE_USE_OLLAMA_FALLBACK=false

# === Whisper.cpp (local transcription — always offline) ===
VITE_WHISPER_MODEL=base.en
VITE_WHISPER_LANGUAGE=en

# === Export Integrations ===
VITE_NOTION_API_KEY=
VITE_SLACK_BOT_TOKEN=
VITE_SLACK_CHANNEL_ID=

# === Enterprise Security ===
VITE_ENABLE_E2E_ENCRYPTION=true
VITE_ENCRYPTION_KEY=
VITE_ENABLE_AUDIT_LOGS=true
VITE_SSO_PROVIDER=none
VITE_SSO_TENANT_ID=
VITE_SSO_CLIENT_ID=

# === Multi-Tenant / Team ===
VITE_ENABLE_TEAMS=false
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# === Branding ===
VITE_BRAND_NAME=Devora Devs
VITE_BRAND_URL=http://devoradevs.xyz/
VITE_WATERMARK_VISIBLE=true

# === App Config ===
VITE_APP_VERSION=1.0.0-enterprise
VITE_ENABLE_ANALYTICS=false
