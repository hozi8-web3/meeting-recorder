{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "meeting-recorder",
  "version": "1.0.2",
  "identifier": "com.hozai.meeting-recorder",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "meeting-recorder",
        "width": 1000,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600
      },
      {
        "label": "overlay",
        "title": "Recording...",
        "url": "overlay.html",
        "width": 380,
        "height": 180,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "resizable": false,
        "x": 24,
        "y": 24
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}